rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Uploads are proxied through authenticated Next.js API routes.
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
