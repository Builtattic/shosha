# Clerk dev instance - get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Firebase emulator mode
FIREBASE_PROJECT_ID=shosha-local
FIREBASE_STORAGE_BUCKET=shosha-local.appspot.com
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Optional integrations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_DISCOVERY_MODEL=gemini-2.5-flash
X_BEARER_TOKEN=
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_GRAPH_VERSION=v22.0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ANONYMOUS_TAG_SALT=
SEED_ADMIN_EMAIL=admin@shosha.local
SEED_ADMIN_PASSWORD=
NODE_ENV=development
