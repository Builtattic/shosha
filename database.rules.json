{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".indexOn": ["username", "createdAt", "followingAccounts", "trustBadgePending", "role"],
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
        "role": {
          ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin'"
        }
      }
    },

    "accounts": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["score", "usernameLower", "displayNameLower", "claimedBy", "slug"]
    },

    "reports": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["createdAt", "accountId", "reporterId", "hashedUserId", "disputeStatus"]
    },

    "reportMetadata": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["reportId", "profileId"]
    },

    "ledgerEntries": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["profileId", "reportId", "timestamp"]
    },

    "events": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["subjectId", "reporterId", "timestamp", "status"]
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
        ".indexOn": ["createdAt", "status", "read"]
      }
    },

    "disputes": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["userId", "accountId", "status"]
    },

    "claimRequests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["status", "userId"]
    },

    "auditRequests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["createdAt", "status"]
    },

    "reportVotes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["reportId", "userId"]
    },

    "reportComments": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["reportId"]
    },

    "bubbles": {
      ".read": "auth != null",
      ".indexOn": ["createdAt", "createdBy"],
      "$bubbleId": {
        ".write": "!data.exists() && newData.child('createdBy').val() === auth.uid || data.child('createdBy').val() === auth.uid"
      }
    },

    "bubbleMembers": {
      ".read": "auth != null",
      ".indexOn": ["bubbleId", "userId"],
      "$memberId": {
        ".write": "!data.exists() && newData.child('userId').val() === auth.uid || data.child('userId').val() === auth.uid || root.child('bubbles').child(newData.child('bubbleId').val()).child('createdBy').val() === auth.uid"
      }
    },

    "swipeRecords": {
      ".read": false,
      ".write": false,
      ".indexOn": ["userId", "accountId"]
    },

    "deletionRequests": {
      ".read": false,
      ".write": false,
      ".indexOn": ["userId", "status", "createdAt"]
    },

    "siteSettings": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    }
  }
}
