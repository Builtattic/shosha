{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".indexOn": ["username", "createdAt"],
      "$uid": {
        ".read": "$uid === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true"
      }
    },

    "accounts": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["score", "usernameLower", "displayNameLower", "claimedBy"]
    },

    "reports": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["createdAt", "accountId", "reporterId", "hashedUserId", "disputeStatus"]
    },

    "reportMetadata": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["reportId", "profileId"]
    },

    "ledgerEntries": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["profileId", "reportId", "timestamp"]
    },

    "events": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".indexOn": ["subjectId", "reporterId", "timestamp", "status"]
    },

    "notifications": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".indexOn": ["createdAt", "status"]
      }
    },

    "disputes": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },

    "siteSettings": {
      ".read": "auth !== null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },

    "reportVotes": {
      ".indexOn": ["reportId", "userId"]
    },
    "claimRequests": {
      ".indexOn": ["status"]
    },
    "auditRequests": {
      ".indexOn": ["createdAt"]
    },
    "reportComments": {
      ".indexOn": ["reportId"]
    }
  }
}
